generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Trip {
  id           String     @id @default(cuid())
  name         String
  /**
   * Free-text destination the owner sets at creation — city / province / island.
   * Nullable only so pre-existing trips (created before this field) stay valid;
   * new trips always set it (enforced in the createTrip action).
   */
  destination  String?
  ownerToken   String     @unique
  joinCode     String     @unique
  durationDays Int
  windowStart  DateTime
  windowEnd    DateTime
  status       TripStatus @default(PLANNING)
  createdAt    DateTime   @default(now())
  members      Member[]
  availability Availability[]
  budgets      Budget[]
  votes        Vote[]
}

model Member {
  id           String   @id @default(cuid())
  tripId       String
  displayName  String
  memberToken  String   @unique
  /** Crewmate colour key (see lib/crew.ts palette). Unique per trip so no two members clash. */
  color        String?
  joinedAt     DateTime @default(now())
  trip         Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  availability Availability[]
  budget       Budget?
  votes        Vote[]

  @@index([tripId])
  @@unique([tripId, color])
}

model Availability {
  id       String   @id @default(cuid())
  tripId   String
  memberId String
  date     DateTime @db.Date
  isFree   Boolean
  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, date])
  @@index([tripId, date])
}

model Budget {
  id       String @id @default(cuid())
  tripId   String
  memberId String @unique
  /** Minimum of the member's budget range. */
  amount    Int
  /** Maximum of the range. Nullable on legacy single-value rows — treat as == amount. */
  amountMax Int?
  trip     Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Vote {
  id       String       @id @default(cuid())
  tripId   String
  memberId String
  category VoteCategory
  value    String
  trip     Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  member   Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, category])
  @@index([tripId, category])
}

enum TripStatus {
  PLANNING
  DECIDED
  ARCHIVED
}

enum VoteCategory {
  // The owner sets the destination directly, so ACTIVITY is the only thing the
  // group votes on. (REGION was removed once its last dead rows were cleared.)
  ACTIVITY
}
